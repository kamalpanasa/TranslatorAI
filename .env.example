# Application Settings
PROJECT_NAME="Multilingual Translation API"
ENV="development"
API_V1_STR="/api/v1"

# Security & Authentication
# Generated via: openssl rand -hex 32
JWT_SECRET="super-secret-jwt-key-replace-in-production-12345"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI/ML Models
NLLB_MODEL_NAME="facebook/nllb-200-distilled-600M"
WHISPER_MODEL_NAME="base"

# OCR Settings (Windows Tesseract OCR executable path)
TESSERACT_CMD="C:\\Program Files\\Tesseract-OCR\\tesseract.exe"

# Storage & Database (Supabase)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_KEY="your-anon-or-service-role-key"

# Limits & Uploads
MAX_FILE_SIZE_MB=50
